{
  "manifest_version": 3,
  "name": "Redmine Notificações",
  "version": "1.0.0",
  "description": "Notificações inteligentes para suas demandas no Redmine — prazos, status, prioridade e comentários.",
  "permissions": [
    "alarms",
    "notifications",
    "storage",
    "badges"
  ],
  "host_permissions": [
    "https://*/*",
    "http://*/*"
  ],
  "background": {
    "service_worker": "background/service-worker.js"
  },
  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "options_ui": {
    "page": "options/options.html",
    "open_in_tab": true
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
